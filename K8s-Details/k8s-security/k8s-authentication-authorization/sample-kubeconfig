apiVersion: v1
kind: Config

clusters:           
- name: my-cluster
  cluster:
    server: https://192.168.1.100:6443
    certificate-authority: /home/user/.kube/ca.crt
- name: another-cluster
  cluster:
    server: https://192.168.1.101:6443
    certificate-authority: /home/user/.kube/ca.crt


users:
- name: dev-user
  user:
    client-certificate: /home/user/.kube/dev-user.crt
    client-key: /home/user/.kube/dev-user.key
- name: prod-user
  user:
    client-certificate: /home/user/.kube/prod-user.crt
    client-key: /home/user/.kube/prod-user.key  
    

contexts:                 # context are the combination of user & cluster
- name: dev-context
  context:
    cluster: my-cluster
    user: dev-user
    namespace: default
- name: prod-context
  context:
    cluster: another-cluster
    user: prod-user
    namespace: default  

current-context: dev-context